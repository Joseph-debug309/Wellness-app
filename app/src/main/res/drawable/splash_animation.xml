<?xml version="1.0" encoding="utf-8"?>
<!--
    Reverted to the original heartbeat animation structure.
    Uses a group wrapper to allow scaling of the heart path.
-->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="200dp"
            android:height="200dp"
            android:viewportWidth="200"
            android:viewportHeight="200">

            <!-- Background circle -->
            <path
                android:name="circle"
                android:fillColor="#0f172a"
                android:pathData="M100,10 A90,90 0 1,1 99.9,10" />

            <!-- Group for the heart to enable scaling -->
            <group
                android:name="heart_group"
                android:pivotX="100"
                android:pivotY="100">
                <path
                    android:name="heart"
                    android:fillColor="#E03C3C"
                    android:pathData="M100,140 L60,100 A25,25 0 1,1 100,70 A25,25 0 1,1 140,100 Z" />
            </group>
        </vector>
    </aapt:attr>

    <!-- Scaling animation -->
    <target android:name="heart_group">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="800"
                    android:propertyName="scaleX"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:valueFrom="1.0"
                    android:valueTo="1.3" />
                <objectAnimator
                    android:duration="800"
                    android:propertyName="scaleY"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:valueFrom="1.0"
                    android:valueTo="1.3" />
            </set>
        </aapt:attr>
    </target>

</animated-vector>
